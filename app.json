{
  "expo": {
    "name": "JGA Studio",
    "slug": "jga-studio",
    "newArchEnabled": false,
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jgastudio",
    "splash": {
      "image": "./assets/jga-studio-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5F0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.jgastudio"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      "expo-router"
    ],
    "ios": {
      "bundleIdentifier": "com.jaygolding.jgastudio",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "JGA Studio uses the camera so collectors can upload profile photos and share artwork-related images when features requiring image capture are enabled.",
        "NSPhotoLibraryUsageDescription": "JGA Studio needs access to your photo library so you can choose a profile picture."
      }
    },
    "android": {
      "package": "com.jaygolding.jgastudio"
    },
    "extra": {
      "eas": {
        "projectId": "30c25f9b-f53d-4493-8e74-3e41196cf78d"
      }
    }
  }
}
